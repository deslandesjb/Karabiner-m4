{
  "title": "Base Capslock",
  "rules": [
    {
      "description": "Hyperkey - General",
      "manipulators": [
        {
          "description": "capslock = esc(click) | hyper(hold)",
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "right_shift",
              "modifiers": ["right_command", "right_control", "right_option"]
            }
          ],
          "to_if_alone": [
            {
              "key_code": "escape"
            }
          ]
        }
      ]
    },

    {
      "description": "Hyperkey - delete forward (E)",
      "manipulators": [
        {
          "description": "hyper + e = delete forward",
          "type": "basic",
          "from": {
            "key_code": "e",
            "modifiers": {
              "mandatory": ["right_command", "right_control", "right_shift", "right_option"]
            }
          },
          "to": [
            {
              "key_code": "delete_forward"
            }
          ]
        },
        {
          "description": "hyper + cmd + e = delete forward line",
          "type": "basic",
          "from": {
            "key_code": "e",
            "modifiers": {
              "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"]
            }
          },
          "to": [
            {
              "key_code": "delete_forward",
              "modifiers": ["left_command"]
            }
          ]
        },
        {
          "description": "hyper + option + e = delete forward word",
          "type": "basic",
          "from": {
            "key_code": "e",
            "modifiers": {
              "mandatory": ["left_option", "right_command", "right_control", "right_shift", "right_option"]
            }
          },
          "to": [
            {
              "key_code": "delete_forward",
              "modifiers": ["left_option"]
            }
          ]
        }
      ]
    },

    {
      "description": "Hyperkey - alt tab (A)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "q",
            "modifiers": {
              "mandatory": ["right_command", "right_control", "right_shift", "right_option"]
            }
          },
          "to": [
            {
              "key_code": "tab",
              "modifiers": ["right_command"]
            }
          ]
        }
      ]
    },

    {
      "description": "Hyperkey - ctrl tab (Z)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "w",
            "modifiers": {
              "mandatory": ["right_control", "right_command", "right_shift", "right_option"]
            }
          },
          "to": [
            {
              "key_code": "tab",
              "modifiers": ["right_control"]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": ["^company\\.thebrowser\\.Browser$"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "w",
            "modifiers": {
              "mandatory": ["right_control", "right_command", "right_shift", "right_option"]
            }
          },
          "to": [
            {
              "key_code": "w",
              "modifiers": ["right_command", "right_shift", "right_option"]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application",
              "bundle_identifiers": ["^company\\.thebrowser\\.Browser$"]
            }
          ]
        }
      ]
    },

    {
      "description": "Hyperkey + cmd + numbers - select tab (1-2-3)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "1",
            "modifiers": {
              "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"]
            }
          },
          "to": [
            {
              "key_code": "1",
              "modifiers": ["right_control"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "2",
            "modifiers": {
              "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"]
            }
          },
          "to": [
            {
              "key_code": "2",
              "modifiers": ["right_control"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "3",
            "modifiers": {
              "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"]
            }
          },
          "to": [
            {
              "key_code": "3",
              "modifiers": ["right_control"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "4",
            "modifiers": {
              "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"]
            }
          },
          "to": [
            {
              "key_code": "4",
              "modifiers": ["right_control"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "5",
            "modifiers": {
              "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"]
            }
          },
          "to": [
            {
              "key_code": "5",
              "modifiers": ["right_control"]
            }
          ]
        }
      ]
    }
  ]
}
