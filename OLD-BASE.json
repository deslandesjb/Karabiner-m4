{
  "title": "OLD BASE",
  "rules": [
    {
      "description": "Arc & Zen cmd + D & switch tab controls",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "a",
            "modifiers": { "mandatory": ["command", "option"] }
          },
          "to": [
            { "key_code": "left_arrow", "modifiers": ["command", "option"] }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^company\\.thebrowser\\.Browser$"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "d",
            "modifiers": { "mandatory": ["command", "option"] }
          },
          "to": [
            { "key_code": "right_arrow", "modifiers": ["command", "option"] }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^company\\.thebrowser\\.Browser$"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "w",
            "modifiers": { "mandatory": ["command", "option"] }
          },
          "to": [
            { "key_code": "up_arrow", "modifiers": ["command", "option"] }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^company\\.thebrowser\\.Browser$"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "s",
            "modifiers": { "mandatory": ["command", "option"] }
          },
          "to": [
            { "key_code": "down_arrow", "modifiers": ["command", "option"] }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^company\\.thebrowser\\.Browser$"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "w",
            "modifiers": { "mandatory": ["command", "option"] }
          },
          "to": [
            { "key_code": "left_arrow", "modifiers": ["command", "option"] }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^app\\.zen-browser\\.zen$"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "s",
            "modifiers": { "mandatory": ["command", "option"] }
          },
          "to": [
            { "key_code": "right_arrow", "modifiers": ["command", "option"] }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^app\\.zen-browser\\.zen$"]
            }
          ]
        }
      ]
    },
    {
      "description": "Switch tabs with cmd + @",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "non_us_backslash",
            "modifiers": { "mandatory": ["command"] }
          },
          "to": [{ "key_code": "f18", "modifiers": ["command"] }]
        }
      ]
    },
    {
      "description": "Finder switch windows with cmd + @",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "non_us_backslash",
            "modifiers": { "mandatory": ["command"] }
          },
          "to": [{ "key_code": "tab", "modifiers": ["left_control"] }],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^com\\.apple\\.finder$"]
            }
          ]
        }
      ]
    },
    {
      "description": "Apple Music controls",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "play_or_pause" },
          "to": [
            {
              "shell_command": "osascript -e 'tell application \"Music\" to playpause'"
            }
          ]
        },
        {
          "type": "basic",
          "from": { "key_code": "f8" },
          "to": [
            {
              "shell_command": "osascript -e 'tell application \"Music\" to playpause'"
            }
          ]
        }
      ]
    },
    {
      "description": "Window management mac remap opt + A & Z",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "q", "modifiers": { "mandatory": ["option"] } },
          "to": [
            {
              "key_code": "q",
              "modifiers": [
                "left_shift",
                "left_option",
                "left_control",
                "left_command"
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": { "key_code": "w", "modifiers": { "mandatory": ["option"] } },
          "to": [
            {
              "key_code": "w",
              "modifiers": [
                "left_shift",
                "left_option",
                "left_control",
                "left_command"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Mute mac",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "f20" },
          "to": [
            {
              "key_code": "equal_sign",
              "modifiers": [
                "left_shift",
                "left_option",
                "left_control",
                "left_command"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Parentheses () close",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "5" },
          "to": [
            { "key_code": "5" },
            { "key_code": "hyphen" },
            { "key_code": "left_arrow" }
          ]
        }
      ]
    },
    {
      "description": "Braces {} close",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "5", "modifiers": { "mandatory": ["option"] } },
          "to": [
            { "key_code": "5", "modifiers": ["option"] },
            { "key_code": "hyphen", "modifiers": ["option"] },
            { "key_code": "left_arrow" }
          ]
        }
      ]
    },
    {
      "description": "AltTab: command + Tab => command + backslash",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "tab",
            "modifiers": { "mandatory": ["command"] }
          },
          "to": [
            {
              "repeat": true,
              "key_code": "backslash",
              "modifiers": ["command"]
            }
          ],
          "to_after_key_up": [
            { "key_code": "left_control", "modifiers": ["command"] }
          ]
        }
      ]
    },
    {
      "description": "optionTab: option + Tab => option + backslash",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "tab",
            "modifiers": { "mandatory": ["option"] }
          },
          "to": [
            { "repeat": true, "key_code": "backslash", "modifiers": ["option"] }
          ],
          "to_after_key_up": [
            { "key_code": "left_control", "modifiers": ["option"] }
          ]
        }
      ]
    },
    {
      "description": "whatsapp cmd w",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "z",
            "modifiers": { "mandatory": ["command"] }
          },
          "to": [{ "key_code": "h", "modifiers": ["command"] }],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^net\\.whatsapp\\.WhatsApp$"]
            }
          ]
        }
      ]
    },
    {
      "description": "Remap Option + Tab/1/2/3/4 to Control + Tab/1/2/3/4",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "tab",
            "modifiers": { "mandatory": ["option"] }
          },
          "to": [{ "key_code": "tab", "modifiers": ["left_control"] }]
        },
        {
          "type": "basic",
          "from": { "key_code": "1", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "1", "modifiers": ["left_control"] }]
        }
      ]
    }
  ]
}
