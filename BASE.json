{
  "title": "BASE Extras",
  "rules": [
    {
      "description": "Command f1 and f2 to adjust keyboard brightness / opt f1 and f2 to fine adjust",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "f1",
            "modifiers": { "mandatory": ["left_command"] }
          },
          "to": [{ "key_code": "illumination_decrement" }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "f2",
            "modifiers": { "mandatory": ["left_command"] }
          },
          "to": [{ "key_code": "illumination_increment" }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "f1",
            "modifiers": { "mandatory": ["left_option"] }
          },
          "to": [
            { "key_code": "f1", "modifiers": ["left_shift", "left_option"] }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "f2",
            "modifiers": { "mandatory": ["left_option"] }
          },
          "to": [
            { "key_code": "f2", "modifiers": ["left_shift", "left_option"] }
          ]
        }
      ]
    },
    {
      "description": "Spotify & YT Music controls",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "play_or_pause" },
          "to": [
            {
              "shell_command": "osascript -e 'tell application \"Spotify\" to playpause'"
            }
          ]
        },
        {
          "type": "basic",
          "from": { "key_code": "f8" },
          "to": [
            {
              "shell_command": "osascript -e 'tell application \"Spotify\" to playpause'"
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "play_or_pause",
            "modifiers": { "mandatory": ["command"] }
          },
          "to": [
            { "key_code": "b", "modifiers": ["left_shift", "left_option"] }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "f8",
            "modifiers": { "mandatory": ["command"] }
          },
          "to": [
            { "key_code": "b", "modifiers": ["left_shift", "left_option"] }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [{ "product_id": 45929, "vendor_id": 1133 }]
            }
          ],
          "from": {
            "key_code": "volume_increment",
            "modifiers": { "mandatory": ["command"], "optional": ["any"] }
          },
          "to": [
            {
              "shell_command": "osascript -e 'tell application \"Spotify\" to next track'"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [{ "product_id": 45929, "vendor_id": 1133 }]
            }
          ],
          "from": {
            "key_code": "volume_decrement",
            "modifiers": { "mandatory": ["command"], "optional": ["any"] }
          },
          "to": [
            {
              "shell_command": "osascript -e 'tell application \"Spotify\" to previous track'"
            }
          ]
        }
      ]
    },
    {
      "description": "Backtick ` close",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "backslash" },
          "to": [
            { "key_code": "backslash" },
            { "key_code": "backslash" },
            { "key_code": "left_arrow" }
          ]
        }
      ]
    },
    {
      "description": "Press twice period to activate Raycast emoji picker double",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            { "type": "variable_if", "name": "period pressed", "value": 1 }
          ],
          "from": { "key_code": "period" },
          "to": [
            { "key_code": "delete_or_backspace", "hold_down_milliseconds": 10 },
            {
              "key_code": "y",
              "modifiers": [
                "left_shift",
                "left_option",
                "left_control",
                "left_command"
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "period",
            "modifiers": { "optional": ["any"] }
          },
          "to": [{ "set_variable": { "name": "period pressed", "value": 1 } }],
          "to_if_held_down": [{ "key_code": "period" }],
          "parameters": { "basic.to_if_held_down_threshold_milliseconds": 0 },
          "to_delayed_action": {
            "to_if_invoked": [
              { "set_variable": { "name": "period pressed", "value": 0 } }
            ],
            "to_if_canceled": [
              { "set_variable": { "name": "period pressed", "value": 0 } }
            ]
          }
        }
      ]
    }
  ]
}
